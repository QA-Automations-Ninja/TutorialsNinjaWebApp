<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Parallel Cross Browser Suite" parallel="tests" thread-count="3" verbose="1">
    
     <listeners>
        <listener class-name="utilities.ExtentTestListener"/>
    </listeners>

    <!-- Chrome -->
    <test name="Chrome Test">
       <parameter name="browser" value="chrome"/>
    

        <classes>
            <class name="registertests.RegisterMandatoryFieldsTest"/>
            <class name="registertests.RegisterAllFieldsTest"/>
             <class name ="registertests.RegisterWithEmptyFieldsTest"/>
               <class name ="registertests.RegisterPasswordMismatchTest"/>
               <class name ="registertests.RegisterWithExistingEmailTest"/>
               <class name ="registertests.RegisterInvalidEmailTest"/>
        </classes>
    </test>

    <!-- Edge -->
    <test name="Edge Test">
        <parameter name="browser" value="edge"/>
     

        <classes>
            <class name="registertests.RegisterMandatoryFieldsTest"/>
            <class name="registertests.RegisterAllFieldsTest"/>
            <class name ="registertests.RegisterWithEmptyFieldsTest"/>
              <class name ="registertests.RegisterPasswordMismatchTest"/>
              <class name ="registertests.RegisterWithExistingEmailTest"/>
               <class name ="registertests.RegisterInvalidEmailTest"/>
        </classes>
    </test>

    <!-- Firefox -->
    <test name="Firefox Test">
        <parameter name="browser" value="firefox"/>
       
        <classes>
            <class name="registertests.RegisterMandatoryFieldsTest"/>
            <class name="registertests.RegisterAllFieldsTest"/>
            <class name ="registertests.RegisterWithEmptyFieldsTest"/>
              <class name ="registertests.RegisterPasswordMismatchTest"/>
              <class name ="registertests.RegisterWithExistingEmailTest"/>
               <class name ="registertests.RegisterInvalidEmailTest"/>
        </classes>
    </test>

</suite>
